# ==============================================================================
# CONFIGURAÇÕES DO MÓDULO: AEGIS_RUNNER
# ==============================================================================
# Copie este arquivo para ".env" dentro da pasta "aegis_runner".
# ==============================================================================

# ==============================================================================
# PARTE A: CONFIGURAÇÕES GERAIS DO AEGIS (Compartilhadas por todos os robôs)
# ==============================================================================

# 1. Configurações Globais do Playwright (Navegador)
# ------------------------------------------------------------------------------
# Executar em modo headless (sem janela física)? "true" ou "false"
AEGIS_BROWSER_HEADLESS=false

# Canal do navegador (ex: "chrome", "msedge")
AEGIS_BROWSER_CHANNEL=msedge

# Atraso em milissegundos entre as ações físicas (útil para homologação visual)
AEGIS_BROWSER_SLOW_MO=100

# 2. Módulo de Resiliência Cognitiva (Gemini / OpenRouter / LiteLLM)
# ------------------------------------------------------------------------------
# Ativa o self-healing e diagnósticos inteligentes? "true" ou "false"
AEGIS_COGNITIVE_ENABLED=false

# Provedor da API de LLM ("openrouter" ou "litellm" ou "custom")
AEGIS_COGNITIVE_PROVIDER=openrouter

# Chave de API para o provedor configurado
AEGIS_COGNITIVE_API_KEY=

# URL Base para chamadas de LLM (opcional se usar defaults do provedor)
AEGIS_COGNITIVE_BASE_URL=https://openrouter.ai/api/v1

# Modelo LLM para análise visual e diagnóstico
AEGIS_COGNITIVE_MODEL=google/gemini-2.5-flash


# ==============================================================================
# PARTE B: VARIÁVEIS ESPECÍFICAS DE CADA RPA (Devem ser configuradas por bot)
# ==============================================================================

# ------------------------------------------------------------------------------
# RPA 1: Control Center / Bot de Produção (bot_producao.py)
# ------------------------------------------------------------------------------
# URL do portal de administração do Control Center
CONTROL_CENTER_URL=http://localhost:8000

# Credenciais de acesso administrativas (sem fallbacks hardcoded no robô)
CONTROL_CENTER_USER=
CONTROL_CENTER_PASSWORD=

# ------------------------------------------------------------------------------
# RPA 2: Portal Segura (bot_portalsegura.py)
# ------------------------------------------------------------------------------
# URL do Portal Segura
PORTALSEGURA_URL=http://localhost:5173/?e2e=true

# Credenciais de acesso da corretora (sem fallbacks hardcoded no robô)
# Em Azure DevOps: vincular ao Variable Group como variável Secret
PORTALSEGURA_USER=
PORTALSEGURA_PASSWORD=

# ==============================================================================
# PARTE C: AUTENTICAÇÃO SSO / OKTA MFA (para sistemas com 2FA)
# ==============================================================================
# Estas variáveis NUNCA devem constar em dataset_inicial.json ou hardcoded.
# Em local: defina no .env do cenário. Em CI/CD: use Azure Variable Groups.
# ------------------------------------------------------------------------------

# Usuário e senha do sistema protegido por OKTA SSO
OKTA_USER=
OKTA_PASSWORD=

# Secret TOTP (base32) registrada no autenticador OKTA para este usuário de serviço.
# Obtida pelo time de IAM ao criar o usuário de serviço e registrar o fator MFA.
# ATENÇÃO: Tratar com o mesmo nível de sigilo de uma senha. Nunca commitar.
OKTA_TOTP_SECRET=

# Issuer do TOTP (opcional, padrão: sem issuer). Usado apenas para fins de auditoria.
# Exemplo: OKTA_TOTP_ISSUER=empresa.okta.com
OKTA_TOTP_ISSUER=

# ------------------------------------------------------------------------------
# RPA 3: Autocompara (bot_autocompara.py)
# ------------------------------------------------------------------------------
# URL do portal Autocompara
AUTOCOMPARA_URL=https://www.autocompara.com.br/cotacao/sobre-seu-veiculo
