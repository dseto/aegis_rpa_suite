# ==============================================================================
# CONFIGURAÇÕES DO MÓDULO: AEGIS_BLACKBOX (MOCK/SIMULATION SERVER)
# ==============================================================================
# Copie este arquivo para ".env" dentro da pasta "aegis_blackbox".
# ==============================================================================

# Porta HTTP do servidor de simulação local para o PortalSegura (SPA)
AEGIS_BLACKBOX_PORT_PORTALSEGURA=5173

# Porta HTTP do servidor de simulação local para o Control Center (Dashboard)
AEGIS_BLACKBOX_PORT_CONTROL_CENTER=8000

# Diretório para exportação da telemetria de simulações e gravações
AEGIS_BLACKBOX_TELEMETRY_OUT=../telemetry_data

# Executar simulação visual ou silenciosa em lote?
AEGIS_BLACKBOX_SIMULATE_HEADLESS=false
