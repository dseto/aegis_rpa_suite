# ==============================================================================
# CONFIGURAÇÕES DO MÓDULO: AEGIS_MENTOR (IA PAIR-PROGRAMMING SKILLS)
# ==============================================================================
# Copie este arquivo para ".env" dentro da pasta "aegis_mentor".
# ==============================================================================

# Modelo padrão de LLM para guiar o design de seletores e estratégias de automação
AEGIS_MENTOR_MODEL=google/gemini-2.5-pro

# Temperatura da geração de sugestões de código (mais baixa = mais estável/reprodutível)
AEGIS_MENTOR_TEMPERATURE=0.1

# Nível de verbosidade de feedback técnico: "high" (detalhado), "medium" ou "low"
AEGIS_MENTOR_FEEDBACK_LEVEL=high

# Habilitar auditoria contínua de boas práticas de acessibilidade nos seletores?
AEGIS_MENTOR_AUDIT_ACCESSIBILITY=true
