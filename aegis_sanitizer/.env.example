# ==============================================================================
# CONFIGURAÇÕES DO MÓDULO: AEGIS_SANITIZER (DATA VALIDATOR & NORMALIZER)
# ==============================================================================
# Copie este arquivo para ".env" dentro da pasta "aegis_sanitizer".
# ==============================================================================

# Diretório padrão para leitura dos logs brutos de telemetria
AEGIS_SANITIZER_INPUT_DIR=../telemetry_data

# Diretório padrão para salvar os runbooks e datasets limpos
AEGIS_SANITIZER_OUTPUT_DIR=../telemetry_data

# Ativar validação estrita de esquemas de dados de entrada? "true" ou "false"
AEGIS_SANITIZER_STRICT_VALIDATION=true

# Ignorar cliques duplicados ocorridos no mesmo elemento em menos de (ms)
AEGIS_SANITIZER_CLICK_DEBOUNCE_MS=200
